{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Represents a user's public profile data.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The user's unique ID." },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "email"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles stored by UID."
    }
  }
}
